PROMPT='%~ >> '

# NVM stuff
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # Homebrew-installed nvm
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # Standalone nvm


# GPG
export GPG_TTY=$(tty)

# uv tool install (engram, etc.) drops binaries here. Generic; works on any
# machine without naming the user.
export PATH="$HOME/.local/bin:$PATH"
